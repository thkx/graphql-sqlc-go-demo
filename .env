# .env

# 运行环境
ENV=development                  # development / production / test

# 服务端口
PORT=8080

# JWT 密钥（生产必须强随机，至少 32 字节）
JWT_SECRET=your-super-secret-jwt-key-2026-change-me-please

# JWT 过期时间（小时）
JWT_EXPIRY_HOURS=24

# SQLite 数据库路径
DATABASE_PATH=database.sqlite

# Cookie 域名
COOKIE_DOMAIN=localhost
COOKIE_NAME=auth-cookie

# 是否启用 HTTPS（影响 Cookie 的 Secure 标志）
HTTPS_ENABLED=false

# 是否启用 GraphQL Playground（生产建议关闭）
PLAYGROUND_ENABLED=true

# 日志级别
LOG_LEVEL=info

# SQLite 连接池配置
SQL_MAX_OPEN_CONNS=25
SQL_MAX_IDLE_CONNS=25
SQL_CONN_MAX_LIFETIME=5m
SQL_CONN_MAX_IDLETIME=5m